# FleetSafe-VLN configuration
# Source this file before running any VLN scripts.
# No secrets here — IPs and topic names only.

# ── Robot network ─────────────────────────────────────────────────────────────
FLEETSAFE_ROBOT_USER=jetson
FLEETSAFE_ROBOT_HOST=172.20.10.14
FLEETSAFE_ROBOT_TAILSCALE=100.91.232.55
FLEETSAFE_DESKTOP_HOST=172.20.10.2
ROS_DOMAIN_ID=30
ROS_LOCALHOST_ONLY=0

# ── Sensor topics ─────────────────────────────────────────────────────────────
VLN_RGB_TOPIC=/camera/color/image_raw
VLN_DEPTH_TOPIC=/camera/depth/image_raw
VLN_ODOM_TOPIC=/odom_raw
VLN_SCAN_TOPICS="/scan0 /scan1"
VLN_CMD_TOPIC=/cmd_vel

# ── VLN instruction topics ────────────────────────────────────────────────────
VLN_TEXT_TOPIC=/fleetsafe/instruction_text
VLN_VOICE_TOPIC=/fleetsafe/instruction_voice
VLN_PARSED_TOPIC=/fleetsafe/vln/parsed_instruction
VLN_SUBGOAL_TOPIC=/fleetsafe/vln/subgoal
VLN_WAYPOINT_TOPIC=/fleetsafe/vln/waypoints
VLN_UNOM_TOPIC=/fleetsafe/cmd_vel_nominal
VLN_USAFE_TOPIC=/cmd_vel

# ── Policy ────────────────────────────────────────────────────────────────────
VLN_DEFAULT_MODEL=gnm           # gnm | vint | nomad | auto | mock
VLN_MAX_VX=0.12                 # maximum forward speed (m/s)
VLN_MAX_WZ=0.35                 # maximum yaw rate (rad/s)
VLN_SAFETY_RADIUS=0.50          # CBF-QP clearance (m)
VLN_CONTROL_HZ=5                # control loop frequency

# ── Feature flags ─────────────────────────────────────────────────────────────
VLN_ENABLE_SAFETY=1             # 1=require FleetSafe CBF-QP, 0=nominal only
VLN_ENABLE_CERTIFICATES=1       # 1=write JSONL safety certificates
VLN_ENABLE_ASR=1                # 1=search for voice/ASR topics
VLN_ENABLE_GOAL_IMAGE=1         # 1=accept image goal from camera or file

# ── Output paths ──────────────────────────────────────────────────────────────
VLN_TRACE_DIR=results/vln_runs
VLN_CERT_DIR=results/certificates
VLN_TOPOMAP_DIR=topomaps/real_m3pro_hospital

# ── Dashboard ─────────────────────────────────────────────────────────────────
VLN_DASHBOARD_URL=http://172.20.10.2:8000
VLN_DASHBOARD_PORT=8000
