# SSH / robot identity
ROBOT_USER=jetson
ROBOT_HOST=fleetsafe-jetson
ROBOT_IP=172.20.10.14
ROBOT_HOTSPOT_IP=172.20.10.14
ROBOT_TAILSCALE_IP=100.91.232.55
FLEETSAFE_JETSON_HOST=fleetsafe-jetson

# Legacy aliases kept for backward compatibility
FLEETSAFE_RTX_IP=172.20.10.2
FLEETSAFE_ROBOT_IP=172.20.10.14
FLEETSAFE_ROBOT_TAILSCALE_IP=100.91.232.55
FLEETSAFE_ROBOT_SSH_USER=jetson
FLEETSAFE_ROBOT_SSH_HOST=172.20.10.14
ROBOT_SSH_ALIAS=fleetsafe-jetson
ROBOT_PREFERRED_IP=172.20.10.14
ROBOT_SSH="${ROBOT_USER}@${ROBOT_PREFERRED_IP}"

# ROS
ROS_DOMAIN_ID=30
FLEETSAFE_LIVE_DOMAIN=30
FLEETSAFE_PLAYBACK_DOMAIN=99
ROS_LOCALHOST_ONLY=0

# Hardware
FLEETSAFE_ROBOT_TYPE=yahboom_m3pro
FLEETSAFE_CAMERA_MODEL=orbbec_dabai_dcw2
FLEETSAFE_LIDAR_MODEL=tmini_plus_x2

# micro-ROS serial (CP2104 → ttyUSB0 → STM32 MCU → publishes /YB_Node /odom_raw /imu/data_raw)
# Use the STABLE by-id path so reboots do not change the device name.
# Baud 2000000 confirmed from Yahboom's own start_agent.sh and fleetsafe_boot/start_base.sh.
FLEETSAFE_MICRO_ROS_DEVICE=/dev/serial/by-id/usb-Silicon_Labs_CP2104_USB_to_UART_Bridge_Controller_02E0E65D-if00-port0
FLEETSAFE_MICRO_ROS_BAUD=2000000
FLEETSAFE_ROBOT_MCU_DEV=/dev/myserial
FLEETSAFE_ROBOT_MCU_BAUD=2000000

# Yahboom navigation pipeline launch (EKF + IMU filter + laser merger — no MoveIt).
# YB_Node/odom_raw/cmd_vel come from micro-ROS (agent↔STM32), NOT from this launch.
# slam_mapping/bringup.launch.py is the correct Yahboom M3Pro navigation bringup.
FLEETSAFE_YAHBOOM_BASE_LAUNCH=/home/jetson/M3Pro_ws/install/slam_mapping/share/slam_mapping/launch/bringup.launch.py

# LiDAR hardware driver launch override (leave empty — start_yahboom_stack.sh starts
# ldlidar_stl_ros2_node directly on ttyTHS1/ttyTHS2 with topic remapping to scan0/scan1).
FLEETSAFE_YAHBOOM_LIDAR_LAUNCH=

# Camera launch override (leave empty for auto-detect)
FLEETSAFE_YAHBOOM_CAMERA_LAUNCH=

# LiDAR hardware port overrides (leave empty for auto-detect: ttyTHS1, ttyTHS2).
# M3Pro Tmini-plus LiDARs connect to the Jetson's hardware UART pins (ttyTHS), not USB.
FLEETSAFE_LIDAR_1_PORT=
FLEETSAFE_LIDAR_2_PORT=
# LDLiDAR_LD19 = Tmini-plus; LDLiDAR_STL27L = Tmini-pro (921600 baud)
FLEETSAFE_LIDAR_PRODUCT=LDLiDAR_LD19
FLEETSAFE_LIDAR_BAUD=230400

# micro_ros_agent override (leave empty — start_yahboom_stack.sh prefers Yahboom binary)
FLEETSAFE_MICRO_ROS_SERIAL=
FLEETSAFE_MICRO_ROS_BAUD=2000000

# Topic overrides (leave empty for auto-detect via detect_scan_topics.sh)
FLEETSAFE_SCAN_TOPICS=
FLEETSAFE_ODOM_TOPIC=/odom_raw

# Live topics
FLEETSAFE_TOPIC_RGB=/camera/color/image_raw
FLEETSAFE_TOPIC_DEPTH=/camera/depth/image_raw
FLEETSAFE_TOPIC_CAM_INFO_COLOR=/camera/color/camera_info
FLEETSAFE_TOPIC_CAM_INFO_DEPTH=/camera/depth/camera_info
FLEETSAFE_TOPIC_ODOM=/odom_raw
FLEETSAFE_TOPIC_IMU=/imu/data_raw
FLEETSAFE_TOPIC_SCAN0=/scan0
FLEETSAFE_TOPIC_SCAN1=/scan1
FLEETSAFE_TOPIC_CMDVEL=/cmd_vel

# Data directories
FLEETSAFE_BAG_DIR=data/real_robot_bags

# Camera viewer
FLEETSAFE_VIEWER_PORT=8081
FLEETSAFE_VIEWER_URL=http://127.0.0.1:8081

# Command Center
FLEETSAFE_BACKEND_URL=http://127.0.0.1:8000
FLEETSAFE_DASHBOARD_URL=http://127.0.0.1:3000
