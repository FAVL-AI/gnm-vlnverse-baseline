<?xml version="1.0"?>
<!--
  Yahboom RosMaster X3 URDF
  Differential-drive ground robot with RGBD camera and RPLidar A1/A2.

  Coordinate frame: ROS REP-103 (x=forward, y=left, z=up)
  Origin: center of wheel axle, at floor level.

  Physical dimensions:
    Wheelbase:  0.160 m
    Width:      0.220 m
    Length:     0.280 m
    Wheel radius: 0.048 m
    Mass:       2.1 kg
-->
<robot name="yahboom_x3">

  <!-- ── Base ──────────────────────────────────────────────────────────────── -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.048" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.28 0.22 0.08"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.28 0.22 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.8"/>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <inertia ixx="0.010" ixy="0.0" ixz="0.0"
               iyy="0.014" iyz="0.0"
               izz="0.020"/>
    </inertial>
  </link>

  <!-- ── Left drive wheel ──────────────────────────────────────────────────── -->
  <link name="left_wheel_link">
    <visual>
      <geometry>
        <cylinder length="0.025" radius="0.048"/>
      </geometry>
      <material name="black">
        <color rgba="0.05 0.05 0.05 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.025" radius="0.048"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <inertia ixx="0.00014" ixy="0.0" ixz="0.0"
               iyy="0.00014" iyz="0.0"
               izz="0.00024"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0.0 0.1225 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- ── Right drive wheel ─────────────────────────────────────────────────── -->
  <link name="right_wheel_link">
    <visual>
      <geometry>
        <cylinder length="0.025" radius="0.048"/>
      </geometry>
      <material name="black">
        <color rgba="0.05 0.05 0.05 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.025" radius="0.048"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <inertia ixx="0.00014" ixy="0.0" ixz="0.0"
               iyy="0.00014" iyz="0.0"
               izz="0.00024"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0.0 -0.1225 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- ── Front caster ──────────────────────────────────────────────────────── -->
  <link name="caster_front_link">
    <visual>
      <geometry><sphere radius="0.018"/></geometry>
      <material name="dark_grey"><color rgba="0.3 0.3 0.3 1.0"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.018"/></geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.000003" ixy="0.0" ixz="0.0"
               iyy="0.000003" iyz="0.0"
               izz="0.000003"/>
    </inertial>
  </link>

  <joint name="caster_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_front_link"/>
    <origin xyz="0.10 0 -0.030" rpy="0 0 0"/>
  </joint>

  <!-- ── Rear caster ───────────────────────────────────────────────────────── -->
  <link name="caster_rear_link">
    <visual>
      <geometry><sphere radius="0.018"/></geometry>
      <material name="dark_grey"><color rgba="0.3 0.3 0.3 1.0"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.018"/></geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.000003" ixy="0.0" ixz="0.0"
               iyy="0.000003" iyz="0.0"
               izz="0.000003"/>
    </inertial>
  </link>

  <joint name="caster_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_rear_link"/>
    <origin xyz="-0.10 0 -0.030" rpy="0 0 0"/>
  </joint>

  <!-- ── LiDAR ─────────────────────────────────────────────────────────────── -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.038"/>
      </geometry>
      <material name="lidar_blue">
        <color rgba="0.0 0.3 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.038"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.17"/>
      <inertia ixx="0.0002" ixy="0" ixz="0"
               iyy="0.0002" iyz="0"
               izz="0.0002"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.0 0.0 0.105" rpy="0 0 0"/>
  </joint>

  <!-- ── Camera mount ──────────────────────────────────────────────────────── -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.025 0.090 0.025"/>
      </geometry>
      <material name="camera_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.090 0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0"
               izz="0.00001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.12 0 0.07" rpy="0 0.2618 0"/>
  </joint>

  <!-- optical frame (z-forward, x-right, y-down) -->
  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- ── IMU ───────────────────────────────────────────────────────────────── -->
  <link name="imu_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.0000001" ixy="0" ixz="0"
               iyy="0.0000001" iyz="0"
               izz="0.0000001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0.0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ── ros2_control ──────────────────────────────────────────────────────── -->
  <ros2_control name="yahboom_x3_hardware" type="system">
    <hardware>
      <plugin>yahboom_hardware/YahboomSystemHardware</plugin>
      <param name="serial_port">/dev/yahboom</param>
      <param name="baud_rate">115200</param>
      <param name="timeout_ms">100</param>
    </hardware>
    <joint name="left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
