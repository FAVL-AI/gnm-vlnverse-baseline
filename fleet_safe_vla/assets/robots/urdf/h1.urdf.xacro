<?xml version="1.0"?>
<!--
  H1 Humanoid Robot URDF Xacro — Fleet-Safe-VLA-OS
  Based on Unitree H1 specifications.
  19 DOF: 5 per leg (hip_yaw, hip_roll, hip_pitch, knee, ankle) +
          4 per arm (shoulder_pitch, shoulder_roll, elbow, wrist) +
          1 torso (not actuated in this config)

  Mass: ~47 kg
  Height: ~1.8 m (standing)
  Payload: 30 kg
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="h1">

  <!-- ═══════════════════════════════════════════════════════════════
       Parameters
  ═══════════════════════════════════════════════════════════════ -->
  <xacro:property name="PI" value="3.14159265358979"/>
  <xacro:property name="robot_mass" value="47.0"/>

  <!-- ═══════════════════════════════════════════════════════════════
       Materials
  ═══════════════════════════════════════════════════════════════ -->
  <material name="dark_gray">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.4 0.8 1.0"/>
  </material>

  <!-- ═══════════════════════════════════════════════════════════════
       Base / Pelvis
  ═══════════════════════════════════════════════════════════════ -->
  <link name="pelvis">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.07"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.18 0.15"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.18 0.15"/>
      </geometry>
    </collision>
  </link>

  <!-- Torso -->
  <joint name="torso_joint" type="fixed">
    <parent link="pelvis"/>
    <child link="torso_link"/>
    <origin xyz="0.0 0.0 0.15" rpy="0 0 0"/>
  </joint>

  <link name="torso_link">
    <inertial>
      <origin xyz="0.0 0.0 0.15" rpy="0 0 0"/>
      <mass value="15.0"/>
      <inertia ixx="0.2" ixy="0.0" ixz="0.0" iyy="0.18" iyz="0.0" izz="0.08"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.16 0.35"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.16 0.35"/>
      </geometry>
    </collision>
  </link>

  <!-- ═══════════════════════════════════════════════════════════════
       Left Leg macro
  ═══════════════════════════════════════════════════════════════ -->
  <xacro:macro name="leg" params="side sign">
    <!-- Hip Yaw -->
    <joint name="${side}_hip_yaw" type="revolute">
      <parent link="pelvis"/>
      <child link="${side}_hip_yaw_link"/>
      <origin xyz="0.0 ${sign * 0.09} -0.05" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.785" upper="0.785" effort="200" velocity="10"/>
      <dynamics damping="1.0" friction="0.5"/>
    </joint>
    <link name="${side}_hip_yaw_link">
      <inertial>
        <mass value="1.5"/>
        <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.002"/>
      </inertial>
      <visual>
        <geometry><cylinder radius="0.04" length="0.06"/></geometry>
        <material name="dark_gray"/>
      </visual>
      <collision>
        <geometry><cylinder radius="0.04" length="0.06"/></geometry>
      </collision>
    </link>

    <!-- Hip Roll -->
    <joint name="${side}_hip_roll" type="revolute">
      <parent link="${side}_hip_yaw_link"/>
      <child link="${side}_hip_roll_link"/>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-0.523" upper="0.523" effort="200" velocity="10"/>
      <dynamics damping="1.0" friction="0.5"/>
    </joint>
    <link name="${side}_hip_roll_link">
      <inertial>
        <mass value="2.0"/>
        <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.003"/>
      </inertial>
      <visual>
        <geometry><cylinder radius="0.04" length="0.06"/></geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <geometry><cylinder radius="0.04" length="0.06"/></geometry>
      </collision>
    </link>

    <!-- Hip Pitch -->
    <joint name="${side}_hip_pitch" type="revolute">
      <parent link="${side}_hip_roll_link"/>
      <child link="${side}_thigh_link"/>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="200" velocity="10"/>
      <dynamics damping="2.0" friction="0.5"/>
    </joint>
    <link name="${side}_thigh_link">
      <inertial>
        <origin xyz="0.0 0.0 -0.175" rpy="0 0 0"/>
        <mass value="5.0"/>
        <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.005"/>
      </inertial>
      <visual>
        <origin xyz="0.0 0.0 -0.175" rpy="0 0 0"/>
        <geometry><box size="0.07 0.06 0.35"/></geometry>
        <material name="dark_gray"/>
      </visual>
      <collision>
        <origin xyz="0.0 0.0 -0.175" rpy="0 0 0"/>
        <geometry><box size="0.07 0.06 0.35"/></geometry>
      </collision>
    </link>

    <!-- Knee -->
    <joint name="${side}_knee" type="revolute">
      <parent link="${side}_thigh_link"/>
      <child link="${side}_shank_link"/>
      <origin xyz="0.0 0.0 -0.35" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.087" upper="2.443" effort="300" velocity="10"/>
      <dynamics damping="2.0" friction="0.5"/>
    </joint>
    <link name="${side}_shank_link">
      <inertial>
        <origin xyz="0.0 0.0 -0.175" rpy="0 0 0"/>
        <mass value="3.5"/>
        <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.003"/>
      </inertial>
      <visual>
        <origin xyz="0.0 0.0 -0.175" rpy="0 0 0"/>
        <geometry><box size="0.06 0.05 0.35"/></geometry>
        <material name="dark_gray"/>
      </visual>
      <collision>
        <origin xyz="0.0 0.0 -0.175" rpy="0 0 0"/>
        <geometry><box size="0.06 0.05 0.35"/></geometry>
      </collision>
    </link>

    <!-- Ankle -->
    <joint name="${side}_ankle" type="revolute">
      <parent link="${side}_shank_link"/>
      <child link="${side}_ankle_link"/>
      <origin xyz="0.0 0.0 -0.35" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.785" upper="0.785" effort="40" velocity="10"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
    <link name="${side}_ankle_link">
      <inertial>
        <origin xyz="0.05 0.0 -0.03" rpy="0 0 0"/>
        <mass value="1.5"/>
        <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
      </inertial>
      <visual>
        <origin xyz="0.05 0.0 -0.03" rpy="0 0 0"/>
        <geometry><box size="0.22 0.1 0.06"/></geometry>
        <material name="dark_gray"/>
      </visual>
      <collision>
        <origin xyz="0.05 0.0 -0.03" rpy="0 0 0"/>
        <geometry><box size="0.22 0.1 0.06"/></geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- ═══════════════════════════════════════════════════════════════
       Arm macro
  ═══════════════════════════════════════════════════════════════ -->
  <xacro:macro name="arm" params="side sign">
    <!-- Shoulder Pitch -->
    <joint name="${side}_shoulder_pitch" type="revolute">
      <parent link="torso_link"/>
      <child link="${side}_upper_arm_link"/>
      <origin xyz="0.0 ${sign * 0.2} 0.28" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-3.14" upper="3.14" effort="40" velocity="10"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
    <link name="${side}_upper_arm_link">
      <inertial>
        <origin xyz="0.0 0.0 -0.135" rpy="0 0 0"/>
        <mass value="2.0"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0.0 0.0 -0.135" rpy="0 0 0"/>
        <geometry><cylinder radius="0.03" length="0.27"/></geometry>
        <material name="dark_gray"/>
      </visual>
      <collision>
        <origin xyz="0.0 0.0 -0.135" rpy="0 0 0"/>
        <geometry><cylinder radius="0.03" length="0.27"/></geometry>
      </collision>
    </link>

    <!-- Shoulder Roll -->
    <joint name="${side}_shoulder_roll" type="revolute">
      <parent link="${side}_upper_arm_link"/>
      <child link="${side}_upper_arm_roll_link"/>
      <origin xyz="0.0 0.0 -0.27" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-1.57" upper="1.57" effort="40" velocity="10"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
    <link name="${side}_upper_arm_roll_link">
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
      <visual>
        <geometry><cylinder radius="0.025" length="0.04"/></geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <geometry><cylinder radius="0.025" length="0.04"/></geometry>
      </collision>
    </link>

    <!-- Elbow -->
    <joint name="${side}_elbow" type="revolute">
      <parent link="${side}_upper_arm_roll_link"/>
      <child link="${side}_lower_arm_link"/>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="40" velocity="10"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
    <link name="${side}_lower_arm_link">
      <inertial>
        <origin xyz="0.0 0.0 -0.135" rpy="0 0 0"/>
        <mass value="1.5"/>
        <inertia ixx="0.007" ixy="0" ixz="0" iyy="0.007" iyz="0" izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0.0 0.0 -0.135" rpy="0 0 0"/>
        <geometry><cylinder radius="0.025" length="0.27"/></geometry>
        <material name="dark_gray"/>
      </visual>
      <collision>
        <origin xyz="0.0 0.0 -0.135" rpy="0 0 0"/>
        <geometry><cylinder radius="0.025" length="0.27"/></geometry>
      </collision>
    </link>

    <!-- Wrist -->
    <joint name="${side}_wrist" type="revolute">
      <parent link="${side}_lower_arm_link"/>
      <child link="${side}_hand_link"/>
      <origin xyz="0.0 0.0 -0.27" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.57" upper="1.57" effort="10" velocity="10"/>
      <dynamics damping="0.1" friction="0.05"/>
    </joint>
    <link name="${side}_hand_link">
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
      <visual>
        <geometry><box size="0.06 0.08 0.03"/></geometry>
        <material name="dark_gray"/>
      </visual>
      <collision>
        <geometry><box size="0.06 0.08 0.03"/></geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- ═══════════════════════════════════════════════════════════════
       Head / Camera
  ═══════════════════════════════════════════════════════════════ -->
  <joint name="head_joint" type="fixed">
    <parent link="torso_link"/>
    <child link="head_link"/>
    <origin xyz="0.0 0.0 0.38" rpy="0 0 0"/>
  </joint>
  <link name="head_link">
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.006"/>
    </inertial>
    <visual>
      <geometry><box size="0.18 0.16 0.18"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry><box size="0.18 0.16 0.18"/></geometry>
    </collision>
  </link>

  <!-- IMU sensor frame -->
  <joint name="imu_joint" type="fixed">
    <parent link="pelvis"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
  </joint>
  <link name="imu_link"/>

  <!-- ═══════════════════════════════════════════════════════════════
       Instantiate legs and arms
  ═══════════════════════════════════════════════════════════════ -->
  <xacro:leg side="left"  sign="1"/>
  <xacro:leg side="right" sign="-1"/>
  <xacro:arm side="left"  sign="1"/>
  <xacro:arm side="right" sign="-1"/>

  <!-- ═══════════════════════════════════════════════════════════════
       ROS2 Control hardware interface
  ═══════════════════════════════════════════════════════════════ -->
  <ros2_control name="h1_control" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
    </hardware>
    <xacro:macro name="joint_interface" params="joint_name">
      <joint name="${joint_name}">
        <command_interface name="effort">
          <param name="min">-300</param>
          <param name="max">300</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
    </xacro:macro>
    <xacro:joint_interface joint_name="left_hip_yaw"/>
    <xacro:joint_interface joint_name="left_hip_roll"/>
    <xacro:joint_interface joint_name="left_hip_pitch"/>
    <xacro:joint_interface joint_name="left_knee"/>
    <xacro:joint_interface joint_name="left_ankle"/>
    <xacro:joint_interface joint_name="right_hip_yaw"/>
    <xacro:joint_interface joint_name="right_hip_roll"/>
    <xacro:joint_interface joint_name="right_hip_pitch"/>
    <xacro:joint_interface joint_name="right_knee"/>
    <xacro:joint_interface joint_name="right_ankle"/>
    <xacro:joint_interface joint_name="left_shoulder_pitch"/>
    <xacro:joint_interface joint_name="left_shoulder_roll"/>
    <xacro:joint_interface joint_name="left_elbow"/>
    <xacro:joint_interface joint_name="left_wrist"/>
    <xacro:joint_interface joint_name="right_shoulder_pitch"/>
    <xacro:joint_interface joint_name="right_shoulder_roll"/>
    <xacro:joint_interface joint_name="right_elbow"/>
    <xacro:joint_interface joint_name="right_wrist"/>
  </ros2_control>

</robot>
